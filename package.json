{
  "name": "nas-vs-minipc-vs-cloud-tco",
  "version": "0.0.0",
  "description": "Multi-year total-cost-of-ownership comparison for NAS, mini PC, and cloud services",
  "license": "MIT",
  "author": "MiniPCLab",
  "type": "module",
  "bin": {
    "tco-compare": "./dist/cli/main.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schema": {
      "default": "./dist/schema/scenario.schema.json"
    },
    "./examples/*": {
      "default": "./dist/examples/*"
    }
  },
  "files": [
    "dist/index.js",
    "dist/index.d.ts",
    "dist/core/",
    "dist/schema/",
    "dist/format/",
    "dist/cli/",
    "dist/examples/",
    "src/schema/scenario.schema.json",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "pnpm clean && pnpm build:package && pnpm build:widget",
    "build:package": "tsc -p tsconfig.build.json && pnpm build:schema && pnpm build:examples",
    "build:schema": "node scripts/precompile-schema.mjs",
    "build:examples": "cp -r examples/ dist/examples/",
    "build:widget": "vite build --config vite.config.ts && cp public/_headers dist/widget/",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "clean": "rm -rf dist/",
    "deploy:staging": "pnpm build:widget && wrangler deploy --env staging",
    "deploy:production": "pnpm build:widget && wrangler deploy --env production",
    "destroy:staging": "wrangler delete --env staging",
    "destroy:production": "wrangler delete --env production",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "changeset": "changeset"
  },
  "dependencies": {
    "decimal.js": "^10.5.0",
    "ajv": "^8.17.1",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.28.1",
    "@eslint/js": "^9.24.0",
    "@testing-library/dom": "^10.4.0",
    "@types/node": "^22.14.0",
    "axe-core": "^4.10.3",
    "eslint": "^9.24.0",
    "fast-check": "^4.1.0",
    "jsdom": "^26.0.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.0",
    "vitest": "^3.1.0",
    "@vitest/coverage-v8": "^3.1.0",
    "wrangler": "^4.11.0",
    "ajv-formats": "^3.0.1"
  },
  "packageManager": "pnpm@10.8.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "tco",
    "total-cost-of-ownership",
    "nas",
    "mini-pc",
    "cloud",
    "financial-comparison",
    "cost-analysis"
  ]
}
