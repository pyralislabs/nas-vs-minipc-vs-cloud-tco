{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:tco:scenario",
  "$comment": "Ajv validates meta-schemas internally. If you see 'no schema with key or ref', set validateSchema: false in the Ajv constructor.",
  "title": "TCO Comparison Scenario",
  "description": "Multi-year financial comparison between owned hardware and cloud rental scenarios",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "label",
    "baseDate",
    "currency",
    "priceBasis",
    "horizonMonths",
    "materialityThresholdPercent",
    "scenarios"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "enum": [1]
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "minLength": 1,
      "maxLength": 64
    },
    "label": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "baseDate": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "currency": {
      "type": "string",
      "minLength": 3,
      "maxLength": 3,
      "pattern": "^[A-Z]{3}$"
    },
    "priceBasis": {
      "type": "string",
      "enum": ["constant", "nominal"]
    },
    "horizonMonths": {
      "type": "integer",
      "minimum": 12,
      "maximum": 120
    },
    "materialityThresholdPercent": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)(\\.\\d+)?$"
    },
    "scenarios": {
      "type": "array",
      "minItems": 2,
      "maxItems": 5,
      "items": {
        "oneOf": [{ "$ref": "#/$defs/ownedScenario" }, { "$ref": "#/$defs/cloudScenario" }]
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "decimalString": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)(\\.\\d{1,8})?$"
    },
    "escalationRate": {
      "type": "string",
      "pattern": "^-?(0|[1-9]\\d*)(\\.\\d+)?$"
    },
    "costLine": {
      "type": "object",
      "required": ["id", "label", "amount"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "minLength": 1,
          "maxLength": 64
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "amount": { "$ref": "#/$defs/decimalString" }
      },
      "additionalProperties": false
    },
    "scheduledCostLine": {
      "type": "object",
      "required": ["id", "label", "amount", "month"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "minLength": 1,
          "maxLength": 64
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "amount": { "$ref": "#/$defs/decimalString" },
        "month": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "recurringCostLine": {
      "type": "object",
      "required": ["id", "label", "monthlyAmount", "annualEscalationRate"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "minLength": 1,
          "maxLength": 64
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "monthlyAmount": { "$ref": "#/$defs/decimalString" },
        "annualEscalationRate": { "$ref": "#/$defs/escalationRate" }
      },
      "additionalProperties": false
    },
    "depreciationPolicy": {
      "type": "object",
      "required": ["depreciableCapitalIds", "usefulLifeMonths", "residualValue"],
      "properties": {
        "depreciableCapitalIds": {
          "type": "array",
          "minItems": 1,
          "maxItems": 50,
          "items": { "type": "string" }
        },
        "usefulLifeMonths": {
          "type": "integer",
          "minimum": 1
        },
        "residualValue": { "$ref": "#/$defs/decimalString" }
      },
      "additionalProperties": false
    },
    "ownedScenario": {
      "type": "object",
      "required": [
        "id",
        "label",
        "kind",
        "assetType",
        "initialCapex",
        "annualEnergyKwh",
        "electricityRatePerKwh",
        "electricityEscalationRate",
        "annualMaintenance",
        "maintenanceEscalationRate"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "minLength": 1,
          "maxLength": 64
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "kind": { "type": "string", "enum": ["owned"] },
        "assetType": { "type": "string", "enum": ["nas", "mini-pc", "other-owned"] },
        "initialCapex": {
          "type": "array",
          "minItems": 1,
          "maxItems": 50,
          "items": { "$ref": "#/$defs/costLine" }
        },
        "scheduledCosts": {
          "type": "array",
          "maxItems": 50,
          "items": { "$ref": "#/$defs/scheduledCostLine" }
        },
        "annualEnergyKwh": { "$ref": "#/$defs/decimalString" },
        "electricityRatePerKwh": { "$ref": "#/$defs/decimalString" },
        "electricityEscalationRate": { "$ref": "#/$defs/escalationRate" },
        "annualMaintenance": { "$ref": "#/$defs/decimalString" },
        "maintenanceEscalationRate": { "$ref": "#/$defs/escalationRate" },
        "otherMonthlyRecurring": {
          "type": "array",
          "maxItems": 50,
          "items": { "$ref": "#/$defs/recurringCostLine" }
        },
        "salvageValue": { "$ref": "#/$defs/decimalString" },
        "depreciation": { "$ref": "#/$defs/depreciationPolicy" },
        "notes": {
          "type": "array",
          "maxItems": 20,
          "items": {
            "type": "string",
            "maxLength": 500
          }
        }
      },
      "additionalProperties": false
    },
    "cloudScenario": {
      "type": "object",
      "required": [
        "id",
        "label",
        "kind",
        "monthlyRecurring",
        "monthlyEgressGb",
        "egressRatePerGb",
        "egressEscalationRate"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "minLength": 1,
          "maxLength": 64
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "kind": { "type": "string", "enum": ["cloud"] },
        "initialCosts": {
          "type": "array",
          "maxItems": 50,
          "items": { "$ref": "#/$defs/costLine" }
        },
        "scheduledCosts": {
          "type": "array",
          "maxItems": 50,
          "items": { "$ref": "#/$defs/scheduledCostLine" }
        },
        "monthlyRecurring": {
          "type": "array",
          "minItems": 1,
          "maxItems": 50,
          "items": { "$ref": "#/$defs/recurringCostLine" }
        },
        "monthlyEgressGb": { "$ref": "#/$defs/decimalString" },
        "egressRatePerGb": { "$ref": "#/$defs/decimalString" },
        "egressEscalationRate": { "$ref": "#/$defs/escalationRate" },
        "notes": {
          "type": "array",
          "maxItems": 20,
          "items": {
            "type": "string",
            "maxLength": 500
          }
        }
      },
      "additionalProperties": false
    }
  }
}
