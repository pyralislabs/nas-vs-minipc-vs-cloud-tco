# Use the public npm registry. Prevents pnpm from falling back to the
# GitHub Packages npm registry (https://npm.pkg.github.com) when resolving
# unscoped packages like `@types/node`, where GitHub Packages only mirrors
# stale DefinitelyTyped versions. See dependabot run logs for the symptom:
# `ERR_PNPM_NO_MATCHING_VERSION ... while fetching it from
# https://npm.pkg.github.com/`.
registry=https://registry.npmjs.org/